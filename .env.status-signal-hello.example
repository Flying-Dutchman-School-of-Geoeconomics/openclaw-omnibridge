# OpenClaw OmniBridge — Status to Signal Hello Example Environment
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Status Configuration ────────────────────────────────────────────────────

STATUS_ENABLED=true

# Your Status private key derived from your Status mnemonic.
# Derivation path: m/43'/60'/1581'/0'/0 using ethers.js HDNodeWallet.
# KEEP THIS SECRET. Never commit the real value.
STATUS_PRIVATE_KEY_HEX=0xYOUR_STATUS_PRIVATE_KEY_HEX_HERE

# Your Status community ID.
# Derive from your Status community invite link anchor using base58 decode.
# Example shape: 0x8253eccfb6e8b9d256ba7c19587242897f4432f4...
STATUS_COMMUNITY_ID=0xYOUR_COMMUNITY_ID_HERE

# Your Status chat (channel) ID.
# Derive from your Status channel invite link anchor using base58 decode.
# Example shape: 0x03929441230c404213af2a3c06caa422a44f5896...
STATUS_CHAT_ID=0xYOUR_CHAT_ID_HERE

# The Waku content topic the bridge listens on. Do not change this.
STATUS_EXPECTED_TOPIC=/openclaw/1/chat/proto

# Comma-separated Waku bootstrap nodes. Leave empty to use Waku defaults.
STATUS_WAKU_BOOTSTRAP_NODES=

# The Ed25519 public key derived by the bridge's own signing code.
# IMPORTANT: This is NOT the same as the secp256k1 public key from ethers.js.
# To derive this value, run (after npm run build):
#   node --env-file=.env -e "import('./dist/src/channels/status/waku-proof.js').then(m => { console.log(m.deriveStatusPublicKeyHex(process.env.STATUS_PRIVATE_KEY_HEX)); })"
STATUS_ALLOWED_SENDERS=YOUR_ED25519_DERIVED_PUBLIC_KEY_HERE

# ─── Signal Configuration ────────────────────────────────────────────────────

SIGNAL_ENABLED=true

# URL of the running signal-cli daemon (JSON-RPC mode).
# Start daemon with: signal-cli.bat -a +BRIDGE_NUMBER daemon --http 127.0.0.1:8081
SIGNAL_RPC_URL=http://127.0.0.1:8081

# Comma-separated list of Signal phone numbers trusted as inbound senders.
# Format: +CountryCodeNumber (e.g. +12025551234)
SIGNAL_TRUSTED_PEERS=+YOUR_RECIPIENT_SIGNAL_NUMBER_HERE

# ─── Bridge Toggles ──────────────────────────────────────────────────────────

BRIDGE_ENABLE_STATUS=true
BRIDGE_ENABLE_SIGNAL=true

# ─── Local Status Inject Path ────────────────────────────────────────────────
# Enables the deterministic bridge-owned Status inject endpoint at:
#   POST /internal/status-shim/messages
# Protected by loopback-only access and the shared secret below.

STATUS_SHIM_LOCAL_ENABLED=true

# A random URL-safe string of at least 32 characters.
# Use letters, numbers, dash, and underscore only. No spaces.
# Generate example: openssl rand -base64 32 | tr -d '=+/' | cut -c1-36
STATUS_SHIM_SHARED_SECRET=REPLACE_WITH_A_RANDOM_32_CHAR_STRING_HERE

# ─── Policy File ─────────────────────────────────────────────────────────────
# Use forward slashes even on Windows.
OPENCLAW_POLICY_PATH=C:/path/to/openclaw-omnibridge/config/policy.json

# ─── Store Backend ───────────────────────────────────────────────────────────
# Use 'memory' for local testing. Use 'redis' for production with Redis URL.
STORE_BACKEND=memory
# REDIS_URL=redis://localhost:6379
